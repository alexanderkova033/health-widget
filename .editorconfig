root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
ktlint_standard_filename = disabled
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{yml,yaml,json,xml}]
indent_size = 2
