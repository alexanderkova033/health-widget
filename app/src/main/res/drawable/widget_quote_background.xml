<?xml version="1.0" encoding="utf-8"?>
<!-- Full-bleed gradient card background for TipWidget, styled after quote-card widgets
     (e.g. the "Motivation" app) rather than a plain surface fill. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:angle="135"
        android:startColor="@color/widget_gradient_start"
        android:endColor="@color/widget_gradient_end"
        android:type="linear" />
</shape>
