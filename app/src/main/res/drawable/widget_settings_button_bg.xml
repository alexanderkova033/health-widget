<?xml version="1.0" encoding="utf-8"?>
<!-- Shaded circle + thin ring behind the widget's settings gear icon, so it reads as a
     tappable button rather than a bare glyph floating on the gradient. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="oval">
    <solid android:color="@color/widget_settings_button_fill" />
    <stroke android:width="1dp" android:color="@color/widget_card_border" />
</shape>
