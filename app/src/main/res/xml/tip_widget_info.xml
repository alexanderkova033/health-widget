<?xml version="1.0" encoding="utf-8"?>
<!--
    updatePeriodMillis is intentionally 0: Android's built-in widget update period is
    unreliable and has a 30-minute floor, so refresh scheduling is done entirely with our own
    WorkManager job (WidgetScheduler), as recommended for Glance widgets.

    widgetCategory includes keyguard (in addition to home_screen) so TipWidget is eligible for
    lock-screen/communal-hub widget pickers, not just the home screen — without it, the OS
    filters this widget out of that picker before the app is ever involved.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="140dp"
    android:minHeight="90dp"
    android:updatePeriodMillis="0"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen|keyguard"
    android:previewImage="@mipmap/ic_launcher"
    android:description="@string/widget_description" />
