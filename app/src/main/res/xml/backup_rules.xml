<?xml version="1.0" encoding="utf-8"?>
<!-- Pre-Android-12 (API < 31) backup rules.

     The app has no SharedPreferences at all — settings and tip history are Jetpack
     `Preferences DataStore`, which Android stores under files/datastore/, not
     shared_prefs/. A `sharedpref` domain rule (what this file used to contain) silently
     matches nothing, so it looked like backup coverage without actually providing any. This
     targets the real on-disk location instead.

     Only local, non-sensitive data lives there (notification frequency, quiet hours, widget
     style, recent tip text), so including it in backup is safe — see PRIVACY.md's "Backups"
     section for what this means for the user. -->
<full-backup-content>
    <include domain="file" path="datastore/" />
</full-backup-content>
