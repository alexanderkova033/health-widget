<?xml version="1.0" encoding="utf-8"?>
<!--
    No <uses-permission android:name="android.permission.INTERNET" /> here — and it must
    stay that way. HealthWidget's entire value proposition is "100% offline, zero data
    collected"; adding INTERNET would silently break that promise for every future change.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Runtime-requested on API 33+ (FR2/FR3 nudge and sleep-alert notifications). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- FR7: reschedule notifications and the widget refresh after a reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".HealthWidgetApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HealthWidget">

        <activity
            android:name=".settings.presentation.SettingsActivity"
            android:exported="true"
            android:theme="@style/Theme.HealthWidget">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The launcher/home-screen app needs to bind to this to place and update the
             widget, so it must be exported (standard for AppWidget providers). -->
        <receiver
            android:name=".widget.TipWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/tip_widget_info" />
        </receiver>

        <!-- BOOT_COMPLETED is a protected system broadcast, so exported=true here is safe:
             only the system can send it. -->
        <receiver
            android:name=".boot.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- TIMEZONE_CHANGED and TIME_SET are both protected system broadcasts and are on
             Android's exemption list for manifest-declared (static) implicit-broadcast
             receivers, so exported=true here is safe the same way it is for BootReceiver. -->
        <receiver
            android:name=".notifications.ClockChangeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
